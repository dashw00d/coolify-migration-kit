# Env vars for a Laravel/PHP SQLite app running under Coolify.
#
# HOW TO USE:
#   - Paste these into Coolify UI → <your app> → Environment Variables.
#   - Mark EVERY var as "Runtime only" (is_buildtime=false). Build-time vars
#     get passed as --build-arg and bust every Docker layer on value change.
#   - Copy APP_KEY and third-party secrets VERBATIM from the old host. A new
#     APP_KEY invalidates every existing session and encrypted cookie.
#
# The Coolify DB backs env vars encrypted; pasting by UI is safest. If you
# have many vars, import via Laravel tinker inside the coolify container:
#   docker exec -i coolify php /var/www/html/artisan tinker --no-interaction
#   Then: \App\Models\EnvironmentVariable::create(['resourceable_id'=>..., 'key'=>..., 'value'=>..., ...]);

# --- Core ---
APP_NAME=YourApp
APP_ENV=production
APP_DEBUG=false
APP_KEY=                             # base64:... — copy from old .env, don't regenerate
APP_URL=https://yourdomain.com       # use https://stg.yourdomain.com during staging rehearsal
APP_TIMEZONE=UTC

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Database: SQLite on a bind-mount ---
DB_CONNECTION=sqlite
# Container-absolute path. NOT the old host path (e.g. /home/user/webapps/...).
# Two conventions:
#   - Laravel default: database/database.sqlite
#   - Some apps keep it in storage/: storage/database.sqlite (override via DB_SQLITE_DATABASE)
DB_DATABASE=/var/www/html/database/database.sqlite
# DB_SQLITE_DATABASE=/var/www/html/storage/database.sqlite

# --- Sessions / cache / queue ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=database

# --- Auto-migrate on boot ---
# OFF by default. Flip to true for exactly one deploy to apply pending migrations,
# then flip back. entrypoint.sh reads this var.
AUTO_MIGRATE=false

# --- Mail (example: Mailgun via SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Third-party keys ---
# Copy these verbatim from the old host's .env. Examples below, delete what
# doesn't apply and add anything missing.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# STRIPE_KEY=
# STRIPE_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=
